-- Function to create buttons
local function v7(name, text, position)
	local v8 = Instance.new("TextButton")
	v8.Name = name
	v8.BackgroundColor3 = Color3.fromRGB(40, 0, 0)
	v8.BackgroundTransparency = 1  -- Start transparent
	v8.BorderColor3 = Color3.fromRGB(255, 50, 50)
	v8.BorderSizePixel = 2
	v8.Position = position
	v8.Size = UDim2.new(0, 120, 0, 40)
	v8.Font = Enum.Font.SciFi
	v8.Text = text
	v8.TextColor3 = Color3.fromRGB(255, 150, 150)
	v8.TextScaled = true
	v8.TextTransparency = 1  -- Start transparent
	
	-- Button glow
	local v9 = Instance.new("UIStroke")
	v9.Color = Color3.fromRGB(255, 80, 80)
	v9.Thickness = 2
	v9.Transparency = 1  -- Start transparent
	v9.Parent = v8
	
	return v8, v9
end

