-- Function for fade-in animation
local function v14()
	-- Fade in main frame background
	local v15 = game:GetService("TweenService")
	local v16 = v15:Create(v2, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0.1
	})
	
	-- Fade in border glow
	local v17 = v15:Create(v3, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 0.3
	})
	
	-- Fade in title
	local v18 = v15:Create(v4, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		TextTransparency = 0,
		TextStrokeTransparency = 0.8
	})
	
	-- Fade in close button
	local v19 = v15:Create(v5, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		TextTransparency = 0
	})
	
	-- Fade in all buttons
	local v20 = v15:Create(v10, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0,
		TextTransparency = 0
	})
	
	local v21 = v15:Create(v10glow, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 0
	})
	
	local v22 = v15:Create(v11, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0,
		TextTransparency = 0
	})
	
	local v23 = v15:Create(v11glow, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 0
	})
	
	local v24 = v15:Create(v12, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0,
		TextTransparency = 0
	})
	
	local v25 = v15:Create(v12glow, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 0
	})
	
	local v26 = v15:Create(v13, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0,
		TextTransparency = 0
	})
	
	local v27 = v15:Create(v13glow, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 0
	})
	
	-- Play all animations
	v16:Play()
	v17:Play()
	v18:Play()
	v19:Play()
	v20:Play()
	v21:Play()
	v22:Play()
	v23:Play()
	v24:Play()
	v25:Play()
	v26:Play()
	v27:Play()
end

