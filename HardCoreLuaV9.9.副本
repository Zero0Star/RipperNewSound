MB.MouseButton1Click:Connect(function()
    playAudio()
    
    local RunService = game:GetService("RunService")
    local items = {
        "HardcoreOne",
        "HardcoreTwo", 
        "HardcoreITEM",
        "HardcoremUSIC",
        "hardcoreInit"
    }
    local found = {}
    local connection = nil
    local isDone = false
    local lastCount = 0
    
    local function updateProgress()
        local count = 0
        for _, name in ipairs(items) do
            if found[name] then
                count = count + 1
            end
        end

        if count ~= lastCount then
            lastCount = count
            
            pcall(function()
                require(game.Players.LocalPlayer.PlayerGui.MainUI.Initiator.Main_Game)
                    .caption("HardCoreMines Loading: " .. count .. "/5", true)
            end)
            
            if count == 5 then
                isDone = true
                if connection then
                    connection:Disconnect()
                    connection = nil
                end
                
                pcall(function()
                    require(game.Players.LocalPlayer.PlayerGui.MainUI.Initiator.Main_Game)
                        .caption("HardCoreMines is all loaded!", true)
                end)
            end
        end
    end

    connection = RunService.Heartbeat:Connect(function()
        for _, name in ipairs(items) do
            if not found[name] then
                local item = workspace:FindFirstChild(name)
                if item and item:IsA("BoolValue") then
                    found[name] = true
                    updateProgress()
                end
            end
        end
    end)

    updateProgress()

    task.spawn(function()
        local scriptUrls = {
            "https://github.com/Zero0Star/RipperNewSound/blob/master/HardCoreLua2.lua?raw=true",
            "https://github.com/Zero0Star/RipperNewSound/blob/master/HardcoreMineLua.lua?raw=true",
            "https://github.com/Zero0Star/RipperNewSound/blob/master/MinesMusic.lua?raw=true",
            "https://github.com/Zero0Star/RipperNewSound/blob/master/MineItem.lua?raw=true"
        }
        for _, url in ipairs(scriptUrls) do
            if url and url ~= "" then
                pcall(function()
                    local remoteCode = game:HttpGet(url, true)
                    loadstring(remoteCode)()
                end)
                if _ < #scriptUrls then 
                    wait(5)
                end
            end
        end
    end)
    
    task.spawn(function()
        local newSoundId = "rbxassetid://135253167165511"
        
        local function replaceDoorOpenSound(doorModel)
            if not doorModel or not doorModel:IsA("Model") then
                return
            end
            
            local doorMeshPart = doorModel:FindFirstChild("Door")
            if not doorMeshPart or not doorMeshPart:IsA("MeshPart") then
                return
            end
            
            local openSound = doorMeshPart:FindFirstChild("Open")
            if not openSound or not openSound:IsA("Sound") then
                return
            end
            
            openSound.SoundId = newSoundId
        end
        
        local function processRoom(room)
            if not room or not room:IsA("Model") then
                return
            end
            
            local door = room:FindFirstChild("Door")
            if door and door:IsA("Model") then
                replaceDoorOpenSound(door)
            end
            
            room.ChildAdded:Connect(function(child)
                if child.Name == "Door" and child:IsA("Model") then
                    replaceDoorOpenSound(child)
                end
            end)
        end
        
        local function processAllCurrentRooms()
            local currentRooms = workspace:FindFirstChild("CurrentRooms")
            if not currentRooms then
                return
            end
            
            for _, room in ipairs(currentRooms:GetChildren()) do
                processRoom(room)
            end
            
            currentRooms.ChildAdded:Connect(function(room)
                processRoom(room)
            end)
        end
        
        processAllCurrentRooms()
        
        workspace.DescendantAdded:Connect(function(descendant)
            if descendant.Name == "Door" and descendant:IsA("Model") and descendant.Parent and descendant.Parent.Name == "Door" then
                wait(0.1)
                replaceDoorOpenSound(descendant)
            end
        end)
    end)
    
    playAudio()
end)

