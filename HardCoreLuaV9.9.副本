local originalMouseBehavior = UIS.MouseBehavior
local originalMouseIconEnabled = UIS.MouseIconEnabled

local function unlockMouseForDoors()
    UIS.MouseIconEnabled = false
    UIS.MouseBehavior = Enum.MouseBehavior.Default
    
    local success, result = pcall(function()
        game:GetService("StarterGui"):SetCore("ShiftLockEnabled", false)
    end)
    
    local StarterPlayer = game:GetService("StarterPlayer")
    if StarterPlayer then
        StarterPlayer.EnableMouseLockOption = false
    end
end

local function restoreMouseForDoors()
    UIS.MouseBehavior = originalMouseBehavior
    UIS.MouseIconEnabled = originalMouseIconEnabled
    
    local success, result = pcall(function()
        game:GetService("StarterGui"):SetCore("ShiftLockEnabled", true)
    end)
    
    local StarterPlayer = game:GetService("StarterPlayer")
    if StarterPlayer then
        StarterPlayer.EnableMouseLockOption = true
    end
end

local customCursor
local cursorConnection
local cursorScreenGui

local function createCustomCursor()
    cursorScreenGui = Instance.new("ScreenGui")
    cursorScreenGui.Name = "CustomCursorGui"
    cursorScreenGui.ResetOnSpawn = false
    cursorScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    cursorScreenGui.DisplayOrder = 9999
    cursorScreenGui.Parent = playerGui
    
    customCursor = Instance.new("Frame")
    customCursor.Name = "CustomCursor"
    customCursor.Size = UDim2.new(0, 30, 0, 30)
    customCursor.BackgroundColor3 = Color3.fromRGB(255, 222, 189)
    customCursor.BackgroundTransparency = 0.2
    customCursor.ZIndex = 9999
    customCursor.Parent = cursorScreenGui
    
    local cursorCorner = Instance.new("UICorner")
    cursorCorner.CornerRadius = UDim.new(1, 0)
    cursorCorner.Parent = customCursor
    
    local cursorStroke = Instance.new("UIStroke")
    cursorStroke.Color = Color3.fromRGB(255, 240, 220)
    cursorStroke.Thickness = 3
    cursorStroke.Parent = customCursor
    
    local mouse = player:GetMouse()
    customCursor.Position = UDim2.new(0, mouse.X - 15, 0, mouse.Y - 15)
    
    cursorConnection = RunService.RenderStepped:Connect(function()
        if customCursor and customCursor.Parent then
            local mouse = player:GetMouse()
            customCursor.Position = UDim2.new(0, mouse.X - 15, 0, mouse.Y - 15)
        end
    end)
end

local function removeCustomCursor()
    if cursorConnection then
        cursorConnection:Disconnect()
        cursorConnection = nil
    end
    
    if customCursor then
        customCursor:Destroy()
        customCursor = nil
    end
    
    if cursorScreenGui then
        cursorScreenGui:Destroy()
        cursorScreenGui = nil
    end
end

local function KJ4()
    unlockMouseForDoors()
    
    RunService.RenderStepped:Wait()
    
    createCustomCursor()
    
    TweenService:Create(BG, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), 
        {BackgroundTransparency = 0.5}):Play()
    
    TweenService:Create(MC, TweenInfo.new(0.8, Enum.EasingStyle.Back, Enum.EasingDirection.Out), 
        {Position = UDim2.new(0.3, 0, 0.15, 0)}):Play()
end

local function KJ5()
    removeCustomCursor()
    
    TweenService:Create(MC, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), 
        {Position = UDim2.new(0.3, 0, 1.2, 0)}):Play()
    
    TweenService:Create(BG, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), 
        {BackgroundTransparency = 1}):Play()
    
    wait(0.5)
    
    restoreMouseForDoors()
    
    SG:Destroy()
end

