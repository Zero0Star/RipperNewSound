    button.MouseLeave:Connect(function()
        TweenService:Create(
            button,
            TweenInfo.new(0.2),
            {
                BackgroundColor3 = COLORS.BUTTON_BG,
                ImageColor3 = Color3.new(1, 0.2, 0.2)
